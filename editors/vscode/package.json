{
  "name": "json-gen-c",
  "displayName": "json-gen-c Schema Language",
  "description": "Syntax highlighting and language server for json-gen-c schema definition files (.json-gen-c)",
  "version": "0.9.0",
  "publisher": "zltl",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zltl/json-gen-c"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:json-gen-c"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "json-gen-c",
        "aliases": [
          "json-gen-c",
          "JSON Gen C Schema"
        ],
        "extensions": [
          ".json-gen-c"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "json-gen-c",
        "scopeName": "source.json-gen-c",
        "path": "./syntaxes/json-gen-c.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "json-gen-c",
      "properties": {
        "json-gen-c.serverPath": {
          "type": "string",
          "default": "json-gen-c",
          "description": "Path to the json-gen-c executable (must support --lsp flag)."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
